/* pages/zen/zen.wxss */
.container {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #08060e;
}

.bg {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #060510 0%, #090714 50%, #0b091a 100%);
  z-index: 0;
}

.particles {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
}

.particle {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  background: rgba(201,168,124,0.3);
  border-radius: 50%;
  animation: drift linear infinite;
}

@keyframes drift {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 0.3; }
  90% { opacity: 0.3; }
  100% { transform: translateY(-80vh) translateX(20rpx); opacity: 0; }
}

/* 背景脉冲 - 配合声音 */
.bg-pulse {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
  pointer-events: none;
  animation: bgPulse ease-out forwards;
}

@keyframes bgPulse {
  0% { opacity: 1; background: radial-gradient(circle at 50% 40%, rgba(160,150,200,0.12) 0%, transparent 65%); }
  50% { opacity: 0.4; }
  100% { opacity: 0; background: radial-gradient(circle at 50% 40%, rgba(160,150,200,0) 0%, transparent 65%); }
}

/* 涟漪 - 从触摸位置扩散，中心亮边缘暗 + 减速 */
.ripple {
  position: fixed;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(160,150,200,0.6);
  z-index: 2;
  pointer-events: none;
  animation: rippleOut 6s cubic-bezier(0.12, 0, 0.39, 0) forwards;
}

/* 中心亮边缘暗的渐隐光晕 */
.ripple::after {
  content: '';
  position: absolute;
  top: -20%;
  left: -20%;
  width: 140%;
  height: 140%;
  border-radius: 50%;
  background: radial-gradient(circle,
    rgba(160,150,200,0.15) 0%,
    rgba(160,150,200,0.08) 30%,
    rgba(160,150,200,0.02) 60%,
    transparent 80%
  );
  animation: glowFade 6s cubic-bezier(0.12, 0, 0.39, 0) forwards;
}

@keyframes rippleOut {
  0% {
    width: 20rpx; height: 20rpx;
    opacity: 0.8; border-width: 2.5rpx;
    box-shadow: 0 0 20rpx rgba(160,150,200,0.5), 0 0 40rpx rgba(160,150,200,0.2);
  }
  10% {
    opacity: 0.6;
    box-shadow: 0 0 15rpx rgba(160,150,200,0.4), 0 0 30rpx rgba(160,150,200,0.15);
  }
  30% {
    opacity: 0.35; border-width: 1.8rpx;
    box-shadow: 0 0 10rpx rgba(160,150,200,0.25);
  }
  60% {
    opacity: 0.15; border-width: 1rpx;
    box-shadow: 0 0 5rpx rgba(160,150,200,0.1);
  }
  100% {
    width: 2400rpx; height: 2400rpx;
    opacity: 0; border-width: 0.3rpx;
    box-shadow: 0 0 0 transparent;
  }
}

@keyframes glowFade {
  0% { opacity: 1; transform: scale(0.3); }
  20% { opacity: 0.8; }
  50% { opacity: 0.4; transform: scale(1); }
  100% { opacity: 0; transform: scale(1.5); }
}

/* 光晕 - 缓慢呼吸脉动 */
.glow {
  position: fixed;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  z-index: 1;
}

.glow-breathe {
  background: radial-gradient(circle, rgba(140,130,180,0.08) 0%, transparent 70%);
  animation: glowBreathe 8s ease-in-out infinite;
}

@keyframes glowBreathe {
  0%, 100% { opacity: 0.3; transform: translate(-50%,-50%) scale(0.94); }
  50% { opacity: 0.8; transform: translate(-50%,-50%) scale(1.06); }
}

/* 敲击粒子 - 缓慢飘散 */
.strike-dot {
  position: fixed;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: rgba(180,170,220,0.6);
  z-index: 3;
  pointer-events: none;
  transform: translate(-50%, -50%);
  animation: dotFly 2s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

@keyframes dotFly {
  0% { transform: translate(-50%,-50%) translate(0,0) scale(1); opacity: 0.6; }
  30% { opacity: 0.5; }
  100% { transform: translate(-50%,-50%) translate(var(--dx), var(--dy)) scale(0.2); opacity: 0; }
}

/* 图片 */
.img-area {
  position: fixed;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
}

.zen-img {
  width: 100%;
  height: 100%;
  opacity: 0.4;
  transition: opacity 2.5s ease-in-out;
  animation: imgBreathe 8s ease-in-out infinite;
}

.zen-img.striking {
  opacity: 0.6;
}

@keyframes imgBreathe {
  0%, 100% { transform: scale(0.985); filter: brightness(0.9); }
  50% { transform: scale(1.015); filter: brightness(1.1); }
}

/* 图片边缘发光脉冲 */
.img-area::after {
  content: '';
  position: absolute;
  top: -8%;
  left: -8%;
  width: 116%;
  height: 116%;
  border-radius: 50%;
  background: radial-gradient(circle, transparent 50%, rgba(140,130,180,0.08) 70%, transparent 100%);
  pointer-events: none;
  animation: edgeGlow 8s ease-in-out infinite;
}

@keyframes edgeGlow {
  0%, 100% { opacity: 0.3; transform: scale(0.95); }
  50% { opacity: 0.8; transform: scale(1.05); }
}

/* 敲击计数 */
.count {
  position: fixed;
  top: calc(40% + 260rpx);
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: rgba(140,130,180,0.08);
  z-index: 4;
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 100rpx;
  left: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.back-btn:active { opacity: 0.4; }

.back-icon {
  font-size: 40rpx;
  color: rgba(140,130,180,0.15);
}

/* 模式切换 */
.mode-btn {
  position: fixed;
  bottom: 170rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 18rpx 60rpx;
  border-radius: 36rpx;
  background: rgba(140,130,180,0.03);
  border: 1rpx solid rgba(140,130,180,0.08);
  z-index: 10;
}

.mode-btn:active { opacity: 0.5; }

.mode-text {
  font-size: 24rpx;
  color: rgba(140,130,180,0.2);
  letter-spacing: 8rpx;
}
