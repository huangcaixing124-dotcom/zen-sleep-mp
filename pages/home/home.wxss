/* pages/home/home.wxss */
.container {
  min-height: 100vh;
  background: #08060e;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

/* 背景渐变 */
.bg {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #08060e 0%, #0b0914 50%, #0d0a18 100%);
  z-index: 0;
}

/* 粒子 */
.particles {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
}

.particle {
  position: absolute;
  background: rgba(201,168,124,0.5);
  border-radius: 50%;
  animation: drift linear infinite;
  box-shadow: 0 0 6rpx rgba(201,168,124,0.3);
}

@keyframes drift {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  8% { opacity: 0.7; }
  85% { opacity: 0.5; }
  100% { transform: translateY(-100vh) translateX(30rpx); opacity: 0; }
}

/* 标题 */
.title-area {
  position: relative;
  z-index: 2;
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 72rpx;
  color: #c9a87c;
  letter-spacing: 36rpx;
  font-weight: 300;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(201,168,124,0.25);
  letter-spacing: 12rpx;
  margin-top: 16rpx;
}

/* 按钮区域 */
.btn-area {
  position: relative;
  z-index: 2;
  width: 100%;
}

.btn {
  position: relative;
  width: 100%;
  height: 180rpx;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  overflow: hidden;
}

.btn:active {
  transform: scale(0.98);
}

/* 呼吸按钮 */
.btn-breath {
  background: rgba(100,120,190,0.04);
  border: 1rpx solid rgba(100,130,200,0.1);
}

.btn-breath .btn-label {
  color: rgba(140,170,230,0.6);
  font-size: 32rpx;
  letter-spacing: 16rpx;
}

.btn-breath .btn-sub {
  color: rgba(140,170,230,0.2);
  font-size: 20rpx;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

/* 呼吸按钮光晕 */
.btn-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.breath-glow {
  background: radial-gradient(circle, rgba(100,140,210,0.18) 0%, transparent 70%);
  animation: breathPulse 4s ease-in-out infinite;
}

@keyframes breathPulse {
  0%, 100% { transform: translate(-50%,-50%) scale(0.8); opacity: 0.6; }
  50% { transform: translate(-50%,-50%) scale(1.3); opacity: 1; }
}

/* 禅修按钮 */
.btn-zen {
  background: rgba(180,150,100,0.03);
  border: 1rpx solid rgba(201,168,124,0.08);
}

.btn-zen .btn-label {
  color: rgba(201,168,124,0.6);
  font-size: 32rpx;
  letter-spacing: 16rpx;
  position: relative;
  z-index: 2;
}

.btn-zen .btn-sub {
  color: rgba(201,168,124,0.2);
  font-size: 20rpx;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
  position: relative;
  z-index: 2;
}

/* 涟漪环 */
.ripple-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 1.5rpx solid rgba(201,168,124,0.15);
  pointer-events: none;
}

.r1 { width: 40rpx; height: 40rpx; animation: ripple 3s ease-out infinite; }
.r2 { width: 40rpx; height: 40rpx; animation: ripple 3s ease-out 0.6s infinite; }
.r3 { width: 40rpx; height: 40rpx; animation: ripple 3s ease-out 1.2s infinite; }
.r4 { width: 40rpx; height: 40rpx; animation: ripple 3s ease-out 1.8s infinite; }
.r5 { width: 40rpx; height: 40rpx; animation: ripple 3s ease-out 2.4s infinite; }

@keyframes ripple {
  0% { width: 40rpx; height: 40rpx; opacity: 0.2; border-width: 1.5rpx; }
  100% { width: 280rpx; height: 280rpx; opacity: 0; border-width: 0.5rpx; }
}
